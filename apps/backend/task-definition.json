{
  "family": "hybrid-devops-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::<AWS_ACCOUNT_ID>:role/hybrid-devops-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::<AWS_ACCOUNT_ID>:role/hybrid-devops-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "<IMAGE_PLACEHOLDER>",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "3000"
        },
        {
          "name": "AWS_REGION",
          "value": "us-east-1"
        },
        {
          "name": "USE_LOCAL_MOCK",
          "value": "false"
        },
        {
          "name": "DYNAMODB_PRODUCTS_TABLE",
          "value": "ProductsTable-prod"
        },
        {
          "name": "DYNAMODB_ORDERS_TABLE",
          "value": "OrdersTable-prod"
        },
        {
          "name": "AWS_SNS_ORDER_CREATED_ARN",
          "value": "arn:aws:sns:us-east-1:<AWS_ACCOUNT_ID>:OrderCreatedTopic-prod"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/hybrid-devops-backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "backend"
        }
      }
    }
  ]
}
