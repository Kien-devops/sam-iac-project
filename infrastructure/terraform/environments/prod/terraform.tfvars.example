aws_region            = "us-east-1"
environment           = "prod"
vpc_cidr              = "10.0.0.0/16"
public_subnet_cidrs   = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs  = ["10.0.10.0/24", "10.0.11.0/24"]
availability_zones    = ["us-east-1a", "us-east-1b"]

frontend_cpu          = "256"
frontend_memory       = "512"
frontend_desired_count = 2

backend_cpu           = "256"
backend_memory        = "512"
backend_desired_count = 2

# Fill these in after deploying the AWS SAM stack:
# sns_topic_arn         = "arn:aws:sns:us-east-1:123456789012:OrderCreatedTopic-prod"
# products_table        = "ProductsTable-prod"
# orders_table          = "OrdersTable-prod"
